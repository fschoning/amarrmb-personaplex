# PersonaPlex v2 — Environment Configuration
# Copy to .env at the project root and fill in values before running docker-compose.

# ---------------------------------------------------------------------------
# HuggingFace
# ---------------------------------------------------------------------------
HF_TOKEN=                          # set your HF token if model is gated
HF_REPO=                           # leave blank for default kyutai/moshiko-pytorch-bf16

# ---------------------------------------------------------------------------
# Concurrency  (MAX_SESSIONS must match instance_group.count in config.pbtxt)
# ---------------------------------------------------------------------------
MAX_SESSIONS=6

# ---------------------------------------------------------------------------
# Inference
# ---------------------------------------------------------------------------
PERSONAPLEX_FP8=1                  # 1=enable FP8 quantisation (Blackwell)
LM_TEMPERATURE=0.8
LM_TOP_K=250

# ---------------------------------------------------------------------------
# LavaSR v2
# ---------------------------------------------------------------------------
LAVASR_HF_REPO=declinator/lava-sr-v2

# ---------------------------------------------------------------------------
# Gateway WebSocket
# ---------------------------------------------------------------------------
WS_PORT=8998
SESSION_TIMEOUT_S=300

# ---------------------------------------------------------------------------
# TLS (leave blank to run without TLS)
# ---------------------------------------------------------------------------
SSL_CERT=                          # absolute path to server.crt
SSL_KEY=                           # absolute path to server.key
SSL_DIR=./ssl                      # directory mounted into gateway container

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------
GRPC_PORT=8001
HTTP_PORT=8000
METRICS_PORT=8002
