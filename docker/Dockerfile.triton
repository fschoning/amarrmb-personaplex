# docker/Dockerfile.triton
# Triton server container with moshi + LavaSR dependencies installed

# 25.04 = CUDA 12.9 + explicit Blackwell/GB10 (sm_121) support
FROM nvcr.io/nvidia/tritonserver:25.04-py3

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
        libsndfile1 libopus-dev pkg-config \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------
# Replace the container's CPU-only PyTorch with CUDA 13.0 build
# The NGC Triton image ships torch 2.10+cpu which has NO GPU support on
# the DGX Spark (GB10 / Blackwell / sm_121). The +cu130 build from
# NVIDIA's pip index includes full CUDA 13.0 + Blackwell support.
# -----------------------------------------------------------------------
RUN pip uninstall -y torch torchaudio 2>/dev/null; \
    pip install --no-cache-dir \
        torch torchaudio \
        --index-url https://download.pytorch.org/whl/cu130

WORKDIR /app

# Install moshi Python package (provides MimiModel, LMGen, loaders, fp8_quantize)
COPY moshi/ /app/moshi/
RUN pip install --no-cache-dir -e /app/moshi/

# CPU DSP resampler (polyphase filtering for 24→48kHz frame smoothing)
RUN pip install --no-cache-dir soxr

# -----------------------------------------------------------------------
# vLLM for Mixtral brain (NVFP4 support on Blackwell/GB10)
# NVIDIA's index provides aarch64 wheels with sm_121 (GB10) support.
# vLLM also bundles transformers + tokenizer support.
# -----------------------------------------------------------------------
RUN pip install --no-cache-dir \
        vllm \
        --extra-index-url https://pypi.nvidia.com \
    || pip install --no-cache-dir vllm  # fallback to PyPI if NVIDIA index fails

# transformers + sentencepiece (needed by mixtral_brain Python backend)
RUN pip install --no-cache-dir \
        transformers \
        sentencepiece \
        accelerate

# Copy model repository and scripts into image
COPY model_repository/ /models/
COPY scripts/ /app/scripts/
RUN chmod +x /app/scripts/*.sh

# HF_TOKEN is passed at runtime via docker-compose environment, not needed at build time.
# Weights are bind-mounted from the host HF cache at runtime.

ENTRYPOINT ["/app/scripts/start_triton.sh"]
