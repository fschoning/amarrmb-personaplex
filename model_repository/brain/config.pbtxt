name: "brain"
backend: "python"
max_batch_size: 0

input [
  { name: "PROMPT"     data_type: TYPE_STRING  dims: [1] },
  { name: "MAX_TOKENS" data_type: TYPE_INT32   dims: [1] }
]

output [
  { name: "RESPONSE"   data_type: TYPE_STRING  dims: [1] }
]

# Single instance — brain runs one request at a time
# Priority 10 = LOWEST. PP (priority 1) is scheduled first.
# No shared resource — both models use GPU concurrently.
# Brain may be slower but PP frames are never blocked.
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
    rate_limiter {
      priority: 10
    }
  }
]
