name: "brain"
backend: "python"
max_batch_size: 0

input [
  { name: "PROMPT"     data_type: TYPE_STRING  dims: [1] },
  { name: "MAX_TOKENS" data_type: TYPE_INT32   dims: [1] }
]

output [
  { name: "RESPONSE"   data_type: TYPE_STRING  dims: [1] }
]

# Single instance — brain runs one request at a time
# GPU isolation handled by CUDA MPS (hardware SM partitioning).
# Brain gets 20% of SMs via CUDA_MPS_ACTIVE_THREAD_PERCENTAGE.
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]
