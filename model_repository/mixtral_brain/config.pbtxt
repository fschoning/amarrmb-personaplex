name: "mixtral_brain"
backend: "python"
max_batch_size: 0

input [
  { name: "PROMPT"     data_type: TYPE_STRING  dims: [1] },
  { name: "MAX_TOKENS" data_type: TYPE_INT32   dims: [1] }
]

output [
  { name: "RESPONSE"   data_type: TYPE_STRING  dims: [1] }
]

# Single instance — Mixtral runs one request at a time
# Lower priority than personaplex_pipeline (real-time audio)
instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]
